# MongoDB
MONGODB_URI=mongodb://localhost:27017/radio

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_minimum_32_chars_random_secret

# HTTP server
PORT=4322

# Frontend origin allowed to send credentialed requests in dev (Vite dev server).
# Not needed in production since the built SPA is served from the same origin.
FRONTEND_ORIGIN=http://localhost:5173

# File storage — supports ~/ expansion. Defaults to ./uploads if unset.
UPLOAD_DIR=./uploads
MAX_TRACK_UPLOAD_MB=50
MAX_COVER_UPLOAD_MB=5

# Liquidsoap integration
LIQUIDSOAP_DIR=./liquidsoap
# Must match <source-password> in icecast.xml
ICECAST_SOURCE_PASSWORD=change_me_icecast_source_password
ICECAST_HOST=localhost
ICECAST_PORT=8000
ICECAST_MOUNT=/stream
ICECAST_STATUS_URL=http://127.0.0.1:8000/status-json.xsl
STATION_NAME=My Radio
STATION_DESCRIPTION=A self-hosted internet radio station
STATION_GENRE=Various
STATION_PUBLIC_URL=https://radio.example.com

# Set to "true" in production once systemd + sudoers are configured (see docs/DEPLOYMENT.md).
# When "false" (default, dev), structural Liquidsoap changes are logged instead of
# actually invoking `sudo systemctl restart liquidsoap`.
LIQUIDSOAP_RESTART_ENABLED=false
